<Window x:Class="Assignment7.ShitHeadWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Assignment7"
        mc:Ignorable="d"
        Title="Shit Head game" Height="600" Width="1000" Closing="Window_Closing">
    <Grid Name="main" Background="Green">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition Width=".25*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <!-- contents-->

        <!-- player space-->
        <WrapPanel Name="HiddenCardsSpace" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3" Panel.ZIndex="1" Orientation="Horizontal" HorizontalAlignment="Center"/>
        <WrapPanel Name="ShownCardsSpace" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3" Panel.ZIndex="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <WrapPanel Name="HandSpace" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="4" Grid.RowSpan="2" Panel.ZIndex="3" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="top"/>

        <!-- side button, rigth-->
        <ScrollViewer Grid.Column="4" Grid.Row="3" Grid.RowSpan="2" Grid.ColumnSpan="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Name="wrpnlActionButtons"  Orientation="Vertical"  Background="DarkGreen">
                <Button Name="btnPlay" Content="play " Width="100" Height="45" Background="LimeGreen" FontSize="30" ClickMode="Press" Click="OnClickPlay" Margin="2" ToolTip="try to play selected card(s)"/>
                <Button Name="btnTryTopDraw" Content="take a gander" Width="150" Height="40" Background="LimeGreen" FontSize="23" ClickMode="Press" Click="btnTryTopDraw_Click" Margin="2" ToolTip="take and instantly play top card in drawpile, may casue a pickup"/>
                <Button Name="btnPickUpCards" Content="pick up" Width="120" Height="40" Background="LimeGreen" FontSize="23" ClickMode="Press" Click="btnPickUpCards_Click" Margin="2" ToolTip="pick up the card pile and pass your turn"/>
                <Button Name="btnSwap" Content="Swap cards" Width="180" Height="40" Background="LightSlateGray" FontSize="23" ClickMode="Press" Click="btnSwap_Click" Margin="2" ToolTip="[Only for the begining of the game] swap 1 card in hand with 1 card in shown cards"/>
                <Button Name="btnHelp" Content="Help" Width="80" Height="40" Background="DarkGray" FontSize="23" ClickMode="Press" Click="btnHelp_Click" Margin="2" ToolTip="for how the game works, and what each thing does"/>
            </StackPanel>
        </ScrollViewer>
        <!---opponent space, top-->
        <StackPanel Name="OpponentSpace" Grid.ColumnSpan="6" Panel.ZIndex="3" Orientation="Horizontal" HorizontalAlignment="Center"/>
        <!--visals for shared cards-->
        <Canvas Name="Drawpile" Grid.Column="4" Grid.Row="2" Visibility="Visible" Background="Transparent" HorizontalAlignment="Left"/>
        <Canvas Name="Cardpile" Grid.Column="2" Grid.Row="2" Visibility="Visible" Background="Transparent" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <Canvas Name="Discardpile" Grid.Column="0" Grid.Row="2" Visibility="Visible" Background="Transparent" HorizontalAlignment="Right"/>
        <!--buttons for expanded detail on shared card stacks-->
        <Button Name="btnDrawpileClick" Grid.Column="4" Grid.Row="1" Content="deck" Background="DarkGreen" Click="DrawpileClick_Click" Width="90" Height="45" Panel.ZIndex="5" HorizontalAlignment="Left" IsTabStop="False" VerticalAlignment="Bottom" ToolTip="open a window to show remaining cards (updates automatically)"/>
        <Button Name="btnCardpileClick" Grid.Column="2" Grid.Row="1" Content="card pile" Background="DarkGreen" Click="CardpileClick_Click" Width="90" Height="45" Panel.ZIndex="5" HorizontalAlignment="Left" IsTabStop="False" VerticalAlignment="Bottom" ToolTip="open a window to show cards (updates automatically)"/>
        <Button Name="btnDiscardpileClick" Grid.Column="1" Grid.Row="1" Content="discard pile" Background="DarkGreen" Click="DiscardpileClick_Click" Width="90" Height="45" Panel.ZIndex="5" HorizontalAlignment="Left" IsTabStop="False" VerticalAlignment="Bottom" ToolTip="open a window to show cards (updates automatically)"/>

    </Grid>
</Window>
