<Window x:Class="Assignment7.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Assignment7"
        mc:Ignorable="d"
        Title="Main Menue: Shithead" Height="450" Width="800" Closing="Window_Closing">
    <Grid Name="MainGrid" Background="green">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10*"/>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="3*" MinWidth="50" MaxWidth="100"/>
            <ColumnDefinition Width="6.5*" MinWidth="100" MaxWidth="200"/>
            <ColumnDefinition Width="3*" MinWidth="50" MaxWidth="100"/>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="10*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="30*"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="15*"/>
            <RowDefinition Height="70"/>
            <RowDefinition Height="30*"/>
        </Grid.RowDefinitions>

        <!--controlls -->

        <!--buttons -->
        <Button Grid.Column="1" Grid.Row="3" FontSize="20" Name="btnOptions" Content="Options" Background="Gray" Click="btnOptions_Click" ToolTip="open options"/>
        <Button Grid.Column="3" Grid.Row="3" FontSize="20" Name="btnPlay" Content="Play" Background="Gray" Click="btnPlay_Click" ToolTip="start a game"/>
        <Button Grid.Column="5" Grid.Row="3" FontSize="20" Name="btnDeck" Content="Deck" Background="Gray" Click="btnDeck_Click" ToolTip="look at your deck"/>
        <!--title -->
        <Image Grid.Column="1" Grid.Row="0"  Name="imgTitle" Grid.ColumnSpan="5" Grid.RowSpan="3" HorizontalAlignment="Center" Source="/otherImgs/ShitHeadLogo.png"/>
        
        
    </Grid>
</Window>
