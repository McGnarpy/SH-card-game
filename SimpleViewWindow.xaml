<Window x:Class="Assignment7.SimpleViewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Assignment7"
        mc:Ignorable="d"
        Title="SimpleViewWindow" Height="450" Width="800">
    <Grid Background="Green">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition />
        </Grid.RowDefinitions>

        <WrapPanel Name="DisplayPanel" Orientation="Horizontal" Grid.Row="1" Panel.ZIndex="2"/>
        <Button Name="btnReload" Content="⟳" Width="50" Margin="10" Height="30" Click="btnReload_Click" HorizontalAlignment="Left" Panel.ZIndex="1" Background="LightGreen"/>
        <Label x:Name="lblHiddenMessage" Content="Label" HorizontalAlignment="Left" Margin="172,0,0,0" VerticalAlignment="Center" Height="50" Width="502" FontSize="22" FontWeight="DemiBold"/>
    </Grid>
</Window>
